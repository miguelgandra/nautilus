# The software citation's version is read from DESCRIPTION at call time, so citation("nautilus")
# always reports the version actually installed and can never drift from the package. Nothing here
# hardcodes a version, and neither should the README - see the "Citing nautilus" section there.
ver  <- meta$Version
if (is.null(ver) || !length(ver)) ver <- utils::packageVersion("nautilus")
year <- format(Sys.Date(), "%Y")

citHeader("To cite nautilus in publications, please use:")

bibentry(
  bibtype = "Manual",
  title   = "nautilus: An R package for biologging data processing and analysis",
  author  = c(
    person("Miguel", "Gandra", comment = c(ORCID = "0000-0003-1506-5141")),
    person("Bruno M.", "Saraiva"),
    person("Bruno C. L.", "Macena"),
    person("Pedro", "Afonso"),
    person("Jorge", "Fontes")
  ),
  year    = year,
  note    = paste0("R package version ", ver),
  url     = "https://github.com/miguelgandra/nautilus",
  textVersion = paste0(
    "Gandra, M., Saraiva, B. M., Macena, B. C. L., Afonso, P., & Fontes, J. (", year, "). ",
    "nautilus: An R package for biologging data processing and analysis ",
    "(Version ", ver, "). GitHub. https://github.com/miguelgandra/nautilus"
  )
)
