# Keep the software citation's version in sync with DESCRIPTION, and use the
# current year (the citation reflects the version the user actually has).
ver  <- meta$Version
if (is.null(ver) || !length(ver)) ver <- "0.1.0"
year <- format(Sys.Date(), "%Y")

citHeader(
  "To cite nautilus in publications, please cite both the software and the",
  "PILOT-tag reference that describes the tagging system it was built around:"
)

bibentry(
  bibtype = "Manual",
  title   = "nautilus: High-Resolution Archival Tag Data Analysis",
  author  = person("Miguel", "Gandra",
                   comment = c(ORCID = "0000-0003-1506-5141")),
  year    = year,
  note    = paste("R package version", ver),
  url     = "https://github.com/miguelgandra/nautilus"
)

